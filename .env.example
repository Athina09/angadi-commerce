# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nextgen_commerce?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
ML_SERVICE_URL="http://localhost:8000"

# Optional — live LLM for vendor Ask Advisor (falls back to inventory advisor)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Client (Vite) — copy these into client/.env
VITE_API_URL="http://localhost:4000"
AUTH_DEMO_MODE=true
