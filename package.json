{
  "name": "nextgen-commerce",
  "version": "1.0.0",
  "private": true,
  "description": "Hyperlocal e-commerce marketplace monorepo",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev -w nextgen-server",
    "dev:client": "npm run dev -w client",
    "dev:ml": "cd ml-service && uvicorn main:app --reload --port 8000",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "postinstall": "prisma generate",
    "test:concurrency": "tsx scripts/concurrency-test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
