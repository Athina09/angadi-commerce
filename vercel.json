{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "prisma generate && npm run build -w nextgen-server",
  "builds": [
    { "src": "server/src/index.ts", "use": "@vercel/node" },
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "functions": {
    "server/src/**": {
      "includeFiles": "node_modules/.prisma/**"
    },
    "api/**": {
      "includeFiles": "node_modules/.prisma/**"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "server/src/index.ts" }
  ]
}
